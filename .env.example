# Daraja API Configuration
# Get these values from your Safaricom Daraja portal (https://developer.safaricom.co.ke)

# Backend API URL (where your Daraja credentials are securely stored)
VITE_API_URL=http://localhost:8000

# Optional: Daraja environment (sandbox or production)
VITE_DARAJA_ENV=sandbox

# Note: Never commit this file with real credentials!
# Create a .env.local file with your actual values
